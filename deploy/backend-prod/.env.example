# Keep 127.0.0.1 if exposed behind reverse proxy in same host.
APP_BIND_IP=127.0.0.1
SHARED_NETWORK_NAME=lihatin-backbone

# Go app must listen on this exact format
APP_PORT=:8080
ENV=production
GIN_MODE=release

# DB in shared Docker network (must match db-prod .env exactly)
# IMPORTANT: keep database name lowercase `lihatin_go` (not `LihatinGo`)
DATABASE_URL=lihatin_app:CHANGE_ME_APP_PASSWORD_MIN_24_CHARS@tcp(lihatin-mariadb:3306)/lihatin_go?charset=utf8mb4&parseTime=true&loc=Local

# Valkey in shared Docker network
REDIS_ADDR=lihatin-valkey:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_MIN_24_CHARS
REDIS_DB=0

# Auth/session
JWT_SECRET=CHANGE_ME_SUPER_SECRET_MIN_32_CHARS
JWT_EXPIRED=24
REFRESH_TOKEN_EXPIRED=168
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_32_CHARS
SESSION_TTL_HOURS=48
PREMIUM_CODE_SECRET=CHANGE_ME_PREMIUM_CODE_SECRET_MIN_16_CHARS

# API URLs / CORS
FRONTEND_URL=https://app.yourdomain.com
BACKEND_URL=https://api.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com
DOMAIN=yourdomain.com
AUTH_COOKIE_SAME_SITE=lax

# Mail (required by app flows)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=mailer@yourdomain.com
SMTP_PASS=CHANGE_ME_SMTP_PASS
FROM_EMAIL=no-reply@yourdomain.com
FROM_NAME=Lihatin

# Optional
IP_GEOLOCATION_API_KEY=
EXPIRE_EMAIL_VERIFICATION_TOKEN_HOURS=24
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_MIN_32_CHARS
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=openid email profile
DISPOSABLE_EMAIL_BLOCK_LIST_URL=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
SUPPORT_ALERT_EMAILS=
OSS_ENDPOINT=
OSS_REGION=auto
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=lihatin
OSS_PATH_STYLE=auto
OSS_PUBLIC_BASE_URL=
