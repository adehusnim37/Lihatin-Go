# ===========================================
# LIHATIN-GO ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# Required variables are marked with [REQUIRED]
# ===========================================

# -----------------------------------------------------
# DATABASE [REQUIRED]
# -----------------------------------------------------
# MySQL connection string
DATABASE_URL="user:password@tcp(localhost:3306)/LihatinGo?charset=utf8mb4&parseTime=True&loc=Asia%2FJakarta"
TZ="Asia/Jakarta"

# -----------------------------------------------------
# REDIS OR VALKEY [REQUIRED]
# -----------------------------------------------------
REDIS_ADDR="localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# -----------------------------------------------------
# SERVER [REQUIRED]
# -----------------------------------------------------
APP_PORT=":8080"
ENV="development"
BACKEND_URL="http://localhost:8080"
FRONTEND_URL="http://localhost:3000"
DOMAIN=""
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# -----------------------------------------------------
# JWT & SESSION [REQUIRED]
# -----------------------------------------------------
JWT_SECRET="your-jwt-secret-min-32-characters"
JWT_EXPIRED="48"
REFRESH_TOKEN_EXPIRED="168"
SESSION_SECRET="your-session-secret-min-32-chars"
SESSION_TTL_HOURS="24"

# -----------------------------------------------------
# CSRF [REQUIRED in production]
# -----------------------------------------------------
CSRF_SECRET="your-csrf-secret-min-32-characters"

# -----------------------------------------------------
# EMAIL / SMTP [REQUIRED]
# -----------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="no-reply@yourdomain.com"
FROM_NAME="Your App Name"
EXPIRE_EMAIL_VERIFICATION_TOKEN_HOURS="2"

# -----------------------------------------------------
# IP GEOLOCATION [REQUIRED for location features]
# -----------------------------------------------------
IP_GEOLOCATION_API_KEY="your-api-key"

# -----------------------------------------------------
# RATE LIMITING [OPTIONAL]
# -----------------------------------------------------
RATE_LIMIT="100"

# -----------------------------------------------------
# PREMIUM CODE [REQUIRED for premium code redeem feature]
# -----------------------------------------------------
PREMIUM_CODE_SECRET="your-premium-code-secret-min-32-characters"

# -----------------------------------------------------
# OBJECT STORAGE [OPTIONAL]
# S3-compatible endpoint (RustFS/MinIO/R2), should point to S3 API host
# not web console host. Example: https://s3.example.com
# OSS_PATH_STYLE options: auto | path | virtual
# -----------------------------------------------------
OSS_REGION="auto"
OSS_ACCESS_KEY="VGgzxS1PayMXHEr38AW9"
OSS_SECRET_KEY="CeFzK6S5wnpgH74maqME1DVxrsNd0Icy9tQ3GibX"
OSS_BUCKET="lihatin"
OSS_PATH_STYLE="auto"
OSS_PUBLIC_BASE_URL="https://oss.mas-a.de"

# -----------------------------------------------------
# GOOGLE OAUTH [OPTIONAL]
# -----------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID="your-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8080/v1/auth/google/callback"
GOOGLE_OAUTH_SCOPES="email,profile"
